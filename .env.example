# Evolve — per-instance configuration (copy to `.env` and fill in for YOUR project).
# `.env` is gitignored: nothing project-specific is ever committed to the engine repo.
# Every value here is something the engine reads at runtime; the generic prompts/skills
# reference these keys instead of hardcoding any one project's specifics.

# ── Product identity ────────────────────────────────────────────────────────
# The name of the product this Evolve instance maintains. Agents say "the product";
# the charter (CHARTER.md) names + describes it. This is used in dashboards/logs.
EVOLVE_PRODUCT_NAME=YourProduct
# Charter file path — the vision authority every agent judges against. Default: CHARTER.md (repo root).
EVOLVE_CHARTER_PATH=               # blank = CHARTER.md

# ── Fleet (the four machines) ───────────────────────────────────────────────
# Logical names → real ssh hosts. May be VMs, containers, or boxes; any OS.
EVOLVE_ADMIN_HOST=evolve-admin     # runs /evolve-pm + the dashboard (holds the decide-token)
EVOLVE_BRAIN_HOST=evolve-brain     # runs /loop + /evolve (the agent swarm)
EVOLVE_TEST_HOST=evolve-test       # deploy + validate candidate changes here
EVOLVE_UAT_HOST=evolve-uat         # human gate-3 verification here

# ── Repos — the COLLECTION this instance watches ────────────────────────────
# The full set of repos Evolve manages — each with its OWN config (path, branches,
# clone path, spec roots, type) — lives in the registry. Copy evolve.repos.example.yaml
# to evolve.repos.yaml and list your repos there. The dashboard's repo-switcher lists
# them; intake scans every registered repo each pass (per-repo intake mode honored).
EVOLVE_REPOS_FILE=evolve.repos.yaml
# Issue intake mode DEFAULT (per-repo override via the registry's `intake:` field):
#   auto   = process every open issue (the autonomous default).
#   manual = process ONLY issues a human admits in the dashboard (a human vets the issue on GitHub
#            first — so a malicious/prompt-injection issue never reaches an agent; also lets you work
#            specific issues on a high-volume public repo). RECOMMENDED for public/untrusted repos.
EVOLVE_INTAKE_DEFAULT=auto
# The PRIMARY repo's local working path (single-repo fallback when no registry file is present).
# With a registry, each repo's `path` is used; this is just the default.
EVOLVE_TARGET_REPO_PATH=~/repos/your-project

# The keys below are instance-wide DEFAULTS a registry entry may override per repo:
EVOLVE_STAGING_BRANCH=release      # where approved work merges (the staging branch)
EVOLVE_WORLD_BRANCH=main           # the published branch (operator-owned promotion)

# Who counts as THE OPERATOR — comma-separated GitHub logins. Their issues ARE the product vision:
# they skip vision-fit and are never auto-rejected at triage (the operator is the authority). Empty = no one.
EVOLVE_OPERATOR_GH=                 # e.g. your-github-username
# Single-repo FALLBACK — used ONLY when evolve.repos.yaml is absent (most setups use the registry). GH_TOKEN
# is also accepted as an alias for GITHUB_TOKEN.
GITHUB_REPO=                        # e.g. your-org/your-repo

# ── Dependency guard (OPTIONAL, pluggable — Evolve imposes NO dependency model) ──
# If your project wants a deterministic build-time dependency check, point this at a checker (any
# script taking `<worktree> <base_ref>`, printing JSON, exiting 0=clean / non-zero=violations). The
# engine runs it on the changed files during the build. Leave it BLANK for no guard (the default).
EVOLVE_DEP_CHECK_CMD=                 # e.g. "python3 scripts/evolve_dep_check.py" — blank = no guard
# The shipped reference checker (scripts/evolve_dep_check.py) handles the common LAYERED case — a
# "platform" core + "units" (apps/modules) that may import the platform but not each other. If you opt
# into it, set its two knobs; otherwise ignore them:
EVOLVE_PLATFORM_PREFIXES=core         # core package prefixes a unit may depend ON
EVOLVE_APP_GLOB=apps/*                # the unit directories (which must not import each other)

# Spec roots — where this project's C/F/S specs live, as comma-separated repo-relative globs.
# ADVISORY: no engine code reads this var — it exists as context for the agents (the prompts
# reference $EVOLVE_SPEC_ROOTS). The authoritative per-repo setting is `spec_roots:` in the
# registry (evolve.repos.yaml). Blank = the type-aware default (a platform repo: apps/*/specs +
# specs; an app/model repo: specs).
EVOLVE_SPEC_ROOTS=                    # e.g. "apps/*/specs,specs" — blank = sensible per-type default

# ── Target adapter (how to deploy + validate YOUR project) ──────────────────
# EVOLVE_ADAPTER names a directory under adapters/ holding an `adapter.yaml` that maps the engine ops
# (deploy / health / acceptance / seed / scaffold) to YOUR commands. The engine invokes them through
# `scripts/evolve_adapter.py <op> ...`. See adapters/example/ for the contract; copy it to
# adapters/<yourname>/ (gitignored, per-instance) and set this.
EVOLVE_ADAPTER=                      # e.g. "skipper" -> adapters/skipper/adapter.yaml
# Optional values your adapter.yaml MAY reference (not required by the binding itself):
EVOLVE_DEPLOY_CMD=                   # e.g. "./deploy.sh" — your product's full redeploy command
EVOLVE_HEALTH_PATH=                  # e.g. "/api/health"

# ── Evidence images (optional) ──────────────────────────────────────────────
# Where the reproduce/validate agents upload screenshots before linking them on the GitHub issue.
# DEFAULT (blank) = catbox.moe, a free public anonymous host (its URL is public — fine only for
# non-sensitive / mock data). Set this to your OWN uploader (run with the image path as the last arg;
# it must print the resulting URL on stdout) to keep evidence private.
EVOLVE_IMAGE_UPLOAD_CMD=              # blank = catbox.moe default


# ── Tokens & secrets (NEVER commit real values) ─────────────────────────────
#
# GITHUB_TOKEN — a GitHub Personal Access Token, for reading/writing Issues on your managed repos.
#   Create it at: GitHub → Settings → Developer settings → Personal access tokens. A fine-grained
#   token scoped to the repos in evolve.repos.yaml with **Issues: Read & Write** (+ Contents: R/W if
#   Evolve pushes branches) is ideal. For a repo in a DIFFERENT account, put its own token in the var
#   named by that registry entry's `token_env`.
GITHUB_TOKEN=
#
# The two Evolve tokens below are SECRETS YOU GENERATE yourself (not issued by any service) — a shared
# bearer the dashboard checks. Generate each with e.g.:
#     openssl rand -hex 32        # or: python -c "import secrets; print(secrets.token_hex(32))"
#
# EVOLVE_DECIDE_TOKEN — the PARENT token that authorizes gate decisions. Put it ONLY in the .env on
#   evolve-admin (where you + /evolve-pm decide). The dashboard requires it on the decision endpoint;
#   the brain must NOT have it — that's what stops the loop from approving its own gates.
EVOLVE_DECIDE_TOKEN=
#
# EVOLVE_SERVICE_TOKEN — the engine token the brain uses to push runs/gates/events to the dashboard.
#   Generate once; put the SAME value in BOTH the dashboard's .env (evolve-admin) and the brain's .env.
#   It can push/report but is rejected (403) at the decision endpoint.
EVOLVE_SERVICE_TOKEN=
#
EVOLVE_SERVER_URL=http://localhost:8000   # the dashboard URL the brain reports to + the PM reads
#
# ── Dashboard (evolve-admin) — all optional, sensible defaults ──────────────
EVOLVE_DASHBOARD_PORT=             # blank = 8000 (also honors $PORT)
EVOLVE_DASHBOARD_DB=               # blank = ~/.evolve/dashboard.db (the runs/gates SQLite store)
# Auth is token-based (the tokens above). Token-less mode (both tokens unset) works ONLY against a
# loopback dev dashboard — binding a non-loopback address requires the tokens.
#
# EVOLVE_STATE_DIR — where the loop stores per-item run state (default ~/.evolve/runs); set a
#   distinct path to run more than one Evolve instance on one host.
EVOLVE_STATE_DIR=
#
# ── Advanced path overrides (optional — all default under ~/.evolve/) ───────
EVOLVE_OUTBOX=                     # blank = ~/.evolve/outbox.jsonl (queued dashboard posts)
EVOLVE_SPEC_INDEX_CACHE=           # blank = <EVOLVE_STATE_DIR>/spec_index_cache.json (triage dedup)
EVOLVE_COST_DB=                    # blank = ~/.evolve/costs.db (vestigial — no metered cost on the subscription)
